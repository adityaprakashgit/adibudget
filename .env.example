# This single .env file can be used by both:
# 1. the local Firefly III Docker stack in this repo
# 2. the adibudget Express backend

# Firefly III application settings
APP_ENV=local
APP_DEBUG=false
APP_KEY=base64:replace-with-generated-laravel-app-key
APP_URL=http://localhost:8080
SITE_OWNER=owner@localhost
TZ=Asia/Kolkata
LOG_CHANNEL=stderr
TRUSTED_PROXIES=*
STATIC_CRON_TOKEN=replace-with-32-char-token
MAIL_MAILER=log

# Keep Firefly on standard local login for PAT creation.
# Do not enable remote user auth / remote guard here.

# Firefly III database settings
DB_CONNECTION=mysql
DB_HOST=firefly-db
DB_PORT=3306
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=replace-with-db-password

# adibudget backend settings
FIREFLY_BASE_URL=http://localhost:8080
FIREFLY_ACCESS_TOKEN=replace-with-your-firefly-personal-access-token
PORT=3000
